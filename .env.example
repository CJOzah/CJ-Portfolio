# Copy this file to `.env` and provide your token value.
# Token should have access to repos you want listed.
# Classic PAT: `repo` + `read:org`.
# For release/web builds, prefer:
# flutter build web --release --dart-define=GITHUB_TOKEN=your_token_here
# For secure web production, use a backend proxy instead of exposing token in client:
# flutter build web --release --dart-define=GITHUB_PROXY_URL=https://your-domain.vercel.app/api/github-proxy
# Render web service example:
# flutter build web --release --dart-define=GITHUB_PROXY_URL=https://your-render-service.onrender.com/api/github-proxy
GITHUB_TOKEN=""
GITHUB_PROXY_URL=""
